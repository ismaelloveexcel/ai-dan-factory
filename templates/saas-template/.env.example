# ==============================================================================
# SaaS Template — Environment Variables
# ==============================================================================
# Copy this to .env.local and fill in the values before deploying.
# On Vercel, set these in Project → Settings → Environment Variables.
# ==============================================================================

# --- Public (exposed to browser) ---------------------------------------------

# Site metadata (used for SEO / OpenGraph)
NEXT_PUBLIC_BASE_URL=https://your-product.vercel.app
NEXT_PUBLIC_SITE_NAME="Your Product Name"
NEXT_PUBLIC_SITE_DESCRIPTION="One-line description for SEO and social cards"

# Stripe price IDs (from Stripe Dashboard → Products → Pricing)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_SCALE=price_xxx

# Analytics (set one or both — only loads if present)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-product.com
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx

# --- Server-side only --------------------------------------------------------

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (https://resend.com/api-keys)
RESEND_API_KEY=re_xxx
EMAIL_FROM=hello@your-domain.com

# Product name used in welcome email subject line
PRODUCT_NAME="Your Product Name"

# Lead storage directory (defaults to ./data locally, /tmp on Vercel)
# LEADS_DIR=./data
