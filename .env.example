# ==============================================================================
# AI-DAN Factory — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values before running.
# In GitHub Actions, set these as repository secrets.
# ==============================================================================

# --- Required Secrets (GitHub Actions) ----------------------------------------

# Personal Access Token with repo scope for creating repositories
# and searching GitHub for reusable templates (repo discovery).
# GitHub Actions secret name: FACTORY_GITHUB_TOKEN
FACTORY_GITHUB_TOKEN=

# Vercel Deploy Hook URL for triggering deployments.
# GitHub Actions secret name: VERCEL_DEPLOY_HOOK_URL
VERCEL_DEPLOY_HOOK_URL=

# --- AI Enhancement (Recommended) --------------------------------------------

# OpenAI API key for AI-generated copy (headlines, descriptions, CTAs).
# If not set, the factory uses deterministic templates (reduced quality).
# GitHub Actions secret name: OPENAI_API_KEY
OPENAI_API_KEY=

# --- Managing Director Webhook ------------------------------------------------

# Base URL of the AI-DAN Managing Director (Repo 1) for build-completion
# webhook notifications.  When set, notify_director.py POSTs results to
# {FACTORY_BASE_URL}/factory/webhook after each build.
# GitHub Actions secret name: FACTORY_BASE_URL
FACTORY_BASE_URL=

# Shared secret for authenticating factory callbacks to the Managing Director.
# Must match the FACTORY_SECRET configured in the Managing Director.
# GitHub Actions secret name: FACTORY_SECRET
FACTORY_SECRET=

# --- Optional Configuration ---------------------------------------------------

# Template repository owner (defaults to current repository owner).
TEMPLATE_OWNER=

# Template repository name (defaults to current repository name).
TEMPLATE_REPO=

# Path to the SaaS template directory within this repository.
TEMPLATE_PROJECT_DIR=templates/saas-template

# --- Build Control Defaults ---------------------------------------------------

# Maximum number of builds allowed per day (default: 20).
MAX_BUILDS_PER_DAY=20

# Maximum number of parallel builds allowed (default: 3).
MAX_PARALLEL_BUILDS=3

# Minimum ROI threshold to approve a build (default: 1.5).
MIN_ROI_THRESHOLD=1.5

# --- Lifecycle Database -------------------------------------------------------

# Path to the SQLite lifecycle database.
STATE_DB=data/lifecycle.sqlite
